GROQ_API_KEY=your-groq-api-key-here


# Deployed WanGP video generation API (Modal)
WANGP_API_URL=https://sagdafathy--wangp-api-fastapi-app.modal.run

# Groq-hosted Qwen model, used only where explicitly requested
# (agents/prompt_agent.py::generate_video_prompts) -- does not change the
# default model used elsewhere.
QWEN_MODEL=qwen/qwen3-32b

# Optional tuning (defaults shown) -- uncomment to override
WANGP_NUM_VARIANTS=2
WANGP_POLL_INTERVAL_SECONDS=10
WANGP_MAX_WAIT_SECONDS=900